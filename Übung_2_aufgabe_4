#include "nnxt.h"

volatile uint8_t port_1 = 0;
volatile uint8_t port_0 = 0;

void task1(){
    SensorConfig(Port_1, SensorTouch); //Drücken des linken Tasters
    sensor_touch_clicked_t vorheriger_wert_1 = SensorTouch_released;
    sensor_touch_clicked_t touch;
    while(1){
        Touch_Clicked(Port_1, &touch);
        if(vorheriger_wert_1 == SensorTouch_released && touch == SensorTouch_clicked){
            port_1 = 1;
        }
        vorheriger_wert_1 = touch;
        Delay(100);
    }
}
void task2(){
    SensorConfig(Port_0, SensorTouch); //Drücken des rechten Tasters
    sensor_touch_clicked_t vorheriger_wert_2 = SensorTouch_released;
    sensor_touch_clicked_t touch;
    while(1){
        Touch_Clicked(Port_0, &touch);
        if(vorheriger_wert_2 == SensorTouch_released && touch == SensorTouch_clicked){
                port_0 = 1;
        }
        vorheriger_wert_2 = touch;
        Delay(100);
    }
}


void task3(){
    motor_dir_t richtung = Motor_dir_forward;
    MotorPortInit(Port_A);
    MotorPortInit(Port_B);
    while(1){
        if(port_1 == 1){
            Motor_Drive(Port_A, richtung, 35);
            Motor_Drive(Port_B, richtung, 35);
            Delay(1000);
            Motor_Stop(Port_A, Motor_stop_float);
            Motor_Stop(Port_B, Motor_stop_float);
            port_1 = 0;
        }
        if(port_0 == 1){
            if(richtung == Motor_dir_forward){
                richtung = Motor_dir_backward;
            }
            else{
                richtung = Motor_dir_forward;
            }
            port_0 = 0;
        }
    }
}

int main(){
    CreateAndStartTask(task3);
    CreateAndStartTask(task1);
    CreateAndStartTask(task2);
    StartScheduler();

    return 0;
}
